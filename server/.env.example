NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/exam_db"
JWT_ACCESS_SECRET="your_access_secret_here"
JWT_REFRESH_SECRET="your_refresh_secret_here"
JWT_EXAM_SECRET="your_exam_secret_here"
CORS_ORIGIN="http://localhost:5173"
MAX_FILE_SIZE_MB=10
COOKIE_DOMAIN="localhost"

# Google OAuth2 credentials for standard Google account Drive uploads.
# If you do not use OAuth, leave these blank and continue to use service account credentials per-teacher.
GOOGLE_OAUTH_CLIENT_ID="your_oauth_client_id"
GOOGLE_OAUTH_CLIENT_SECRET="your_oauth_client_secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:5000/api/auth/google-drive/callback"

# Note: The following Google Drive and SEB variables are no longer
# required in the .env file. They have been migrated to the database
# and can be configured securely per-teacher from the Settings Dashboard.
#
# GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_FOLDER_ID="1abcdefghijklmnopqrstuvwxyz"
# SEB_CONFIG_KEY="your-seb-config-hash"
